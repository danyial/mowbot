# Client-side: path-only URL — resolved relative to the current host
# Works from any device (localhost, LAN IP, mower.local, etc.)
NEXT_PUBLIC_ROSBRIDGE_URL=/rosbridge

# Server-side: the actual rosbridge server (used by the proxy in server.mjs)
# Im Docker-Stack ist rosbridge direkt auf localhost:9090 erreichbar
ROSBRIDGE_URL=ws://localhost:9090

NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_DEFAULT_LAT=48.1634
NEXT_PUBLIC_DEFAULT_LON=11.3019
NEXT_PUBLIC_DEFAULT_ZOOM=18

# NTRIP service configuration (server-side only)
# Im Docker-Stack liegt die Config im gemounteten Volume
NTRIP_ENV_PATH=/app/config/ntrip.env
